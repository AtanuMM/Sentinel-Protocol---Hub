// 1. Configuration Block
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 2. The Identity Models
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String    // Hashed password for UI login
  role      Role      @default(DEVELOPER)
  services  Service[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  SUPER_ADMIN
  DEVELOPER
}

// 3. The Service & Auth Models
model Service {
  id          String     @id @default(uuid())
  name        String     
  description String?
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id])
  apiKeys     ApiKey[]
  secrets     Secret[]
  auditLogs   AuditLog[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model ApiKey {
  id         String   @id @default(uuid())
  prefix     String   
  hash       String   @unique 
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// 4. The Encryption Models (The Heart of the Vault)
model Secret {
  id             String   @id @default(uuid())
  keyName        String   
  encryptedBlob  String
  authTag        String
  iv             String
  wrappedDek     String
  dekIv          String
  dekTag         String
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([serviceId, keyName]) 
}

model AuditLog {
  id        String   @id @default(uuid())
  serviceId String?  
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  action    String   
  target    String?  
  status    String   
  ipAddress String?
  createdAt DateTime @default(now())
}